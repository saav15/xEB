# ==========================================
# Elite Buffs - Git Ignore Rules
# ==========================================

# MacOS/Windows OS metadata
.DS_Store
Thumbs.db

# Gradle build directories and cache
.gradle/
build/
/build/

# Minecraft Forge run directories (run game from IDE)
/run/
/run-data/

# Application Logs (untracked from git index)
/*.log
/latest.log
/logs/

# Java Virtual Machine Crash logs
hs_err_pid*
replay_pid*

# IntelliJ IDEA IDE settings
.idea/
*.iml
*.ipr
*.iws
out/

# Eclipse IDE settings
.classpath
.project
.settings/
.factorypath
bin/

# NetBeans IDE settings
nbproject/
private/
build.xml
nbbuild/
dist/
nbdist/
.nb-gradle/
